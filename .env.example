# =========================================================================
#                   FinScreen — Environment Configuration
# =========================================================================
# This file is a reference seed. Copy sections into the appropriate files:
#
#   backend/.env          ← FastAPI / Python server settings
#   frontend/.env.local   ← Vite client-side variables (must start with VITE_)
#
# =========================================================================


# -------------------------------------------------------------------------
# BACKEND SETTINGS  →  copy to: backend/.env
# -------------------------------------------------------------------------

PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# SQLite (default, file stored inside backend/)
DATABASE_URL="sqlite+aiosqlite:///./finscreen.db"

# JWT token secrets — use strong random 64-char hex strings in production
JWT_ACCESS_SECRET="finescreen-access-secret-key-12345!"
JWT_REFRESH_SECRET="finescreen-refresh-secret-key-67890!"

# FinEdge rotating API keys
FINEDGE_API_KEY_1="your-real-api-key-1"
FINEDGE_API_KEY_2="your-real-api-key-2"
FINEDGE_API_KEY_3="your-real-api-key-3"
FINEDGE_BASE_URL="https://data.finedgeapi.com"

# FinEdge rate limit (Phase 0). Provider allows 300 calls/min. Every outbound
# FinEdge call (proxy + sync) passes through a global token bucket so this is
# never exceeded. SAFETY keeps headroom under the hard cap; BURST smooths spikes.
FINEDGE_MAX_CALLS_PER_MINUTE="300"
FINEDGE_RATE_LIMIT_SAFETY="0.9"
FINEDGE_RATE_LIMIT_BURST="10"

# Shared proxy cache (Phase 2). Leave empty to use a per-process in-memory
# cache. Set to a Redis URL in production so every web worker shares ONE cache
# and a single upstream call serves them all. If Redis is unreachable the app
# transparently falls back to in-memory.
REDIS_URL=""

# Background sync ownership (Phase 1). The FinEdge → company_metrics sync must
# run in exactly ONE process. Keep true for local single-process dev. In
# production set this to false on the web tier and run `python sync_worker.py`
# once as a dedicated worker.
ENABLE_BACKGROUND_SYNC="true"

# PayU India payment gateway
PAYU_MERCHANT_KEY="GTK42i"
PAYU_MERCHANT_SALT="eCwWELSp"

# CORS — URL of the running frontend
FRONTEND_URL="http://localhost:3000"


# -------------------------------------------------------------------------
# FRONTEND SETTINGS  →  copy to: frontend/.env.local
# -------------------------------------------------------------------------

# Must start with VITE_ to be exposed to the Vite compilation bundle
VITE_API_URL="http://localhost:8000/api"
