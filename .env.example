# =========================================================================
#                   FinScreen Monorepo Env Configurations
# =========================================================================
# Copy this file to:
# - backend/.env           (For Express + Prisma settings)
# - frontend/.env.local    (For Vite environment variables)

# -------------------------------------------------------------------------
# BACKEND SETTINGS (backend/.env)
# -------------------------------------------------------------------------
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL Connection String (configured ready for production swapping)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finscreen?schema=public"

# Cryptographical Session Secrets (Use 64-character long hex keys in production)
JWT_ACCESS_SECRET="finescreen-access-secret-key-12345!"
JWT_REFRESH_SECRET="finescreen-refresh-secret-key-67890!"

# Rotating FinEdge API Keys (Proxy resolves to mock local seed data if set to demo keys)
FINEDGE_API_KEY_1="j5qivf3e5akjxft27hqfaxyfo6ohcrzwvaetde72asg2e7q75zcppnyuc4spbq544mvmtq5pfbkjmlfoj3y2pgflekm5uqks"
FINEDGE_API_KEY_2="demo-key-2"
FINEDGE_API_KEY_3="demo-key-3"

# PayU India Payment Parameters
PAYU_MERCHANT_KEY="GTK42i"
PAYU_MERCHANT_SALT="eCwWELSp"

# Redirections Targets
FRONTEND_URL="http://localhost:3000"

# -------------------------------------------------------------------------
# FRONTEND SETTINGS (frontend/.env.local)
# -------------------------------------------------------------------------
# Must start with VITE_ to be exposed to Vite compilation bundles
VITE_API_URL="http://localhost:5000/api"
